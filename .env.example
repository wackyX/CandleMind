# CandleMind runtime configuration

# ===== LLM provider =====
# CandleMind uses an OpenAI-compatible chat completions API.
# Fill these with your own provider or local model endpoint.
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# Some local providers do not support OpenAI JSON mode.
# Set to false for Ollama / LM Studio if JSON-mode requests fail.
LLM_SUPPORTS_JSON_MODE=true

# ===== Legacy Zep compatibility =====
# CandleMind stock prophecy can use dummy here.
ZEP_API_KEY=dummy

# ===== Stock prophecy local data =====
STOCK_PROPHECY_CACHE_TTL_SECONDS=600
STOCK_PROPHECY_ARCHIVE_DIR=./data/prophecies

# ===== Flask =====
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=True

# ===== Optional frontend override =====
# VITE_API_BASE_URL=http://localhost:5001
